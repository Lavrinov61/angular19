{
  "name": "magnus-photo",
  "version": "0.8.0+133",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:ssr": "ng build",
    "build:ssr:prod": "ng build --configuration production",
    "build:check": "ngc --noEmit -p tsconfig.app.json",
    "dev:front": "ng serve --port 4200",
    "dev:back": "cd backend && PORT=3002 npx tsx watch src/server.ts",
    "dev:ssr": "./scripts/start-dev-ssr.sh",
    "verify": "npm run build:check && cd backend && npx tsc --noEmit && cd .. && ng lint",
    "verify:full": "npm run verify && ng test && cd backend && npm test",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "serve:ssr:magnus-photo": "PORT=${PORT:-4000} node dist/magnus-photo/server/server.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "private": true,
  "type": "module",
