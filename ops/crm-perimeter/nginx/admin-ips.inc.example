# ============================================================================
# admin-ips.inc — белый список публичных IP администраторов CRM
# ----------------------------------------------------------------------------
# Этот файл — ПРИМЕР. Реальный файл хранится по пути
# /etc/nginx/conf.d/admin-ips.inc и генерируется скриптом:
#
#     ADMIN_PUBLIC_IPS='203.0.113.42/32,198.51.100.7/32' \
#     sudo ./scripts/apply-admin-ips.sh
#
# Формат:
#     <ip_cidr> 1;  # <комментарий: кто, откуда, когда>
#
# ВАЖНО:
#   - Каждая строка должна оканчиваться на `1;` (значение $crm_trusted_ip=1).
#   - CIDR обязателен (даже для одиночного IP → /32).
#   - После редактирования вручную: `nginx -t && nginx -s reload`.
#   - НЕ коммить реальные IP в git — храним только в .example.
#
# Как получить собственный публичный IP с рабочего места:
#     curl -s ifconfig.me
#     curl -s https://api.ipify.org
# ============================================================================

# Примеры (закомментированы — раскомментировать и заменить):
# 203.0.113.42/32 1;    # Ростов, администратор, офис, добавлено 2026-04-20
# 198.51.100.7/32 1;    # Сборный 21, reception ПК, добавлено 2026-04-20
# 192.0.2.0/24 1;       # Домашняя сеть владельца, /24 т.к. динамический IP
