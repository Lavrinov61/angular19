{
  "name": "magnus-photo-backend",
  "version": "1.0.0",
  "description": "Backend API for Magnus Photo Application",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:scheduler": "PROCESS_ROLE=scheduler tsx watch src/scheduler.ts",
    "dev:worker-outbound": "PROCESS_ROLE=worker-outbound tsx watch src/workers/outbound.ts",
    "dev:worker-ai": "PROCESS_ROLE=worker-ai tsx watch src/workers/ai.ts",
    "dev:worker-bot": "PROCESS_ROLE=worker-bot tsx watch src/workers/bot.ts",
    "dev:telephony": "PROCESS_ROLE=telephony PORT=3009 tsx watch src/telephony.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:telephony": "PROCESS_ROLE=telephony PORT=${PORT:-3009} node dist/telephony.js",
    "migrate": "tsx src/database/migrate.ts",
    "migrate:firestore": "tsx migrations/firestore-to-postgresql.ts",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "webhook:setup:telegram": "tsx scripts/webhook-setup-telegram.ts set",
    "webhook:setup:vk": "tsx scripts/webhook-setup-vk.ts",
    "webhook:setup:whatsapp": "tsx scripts/webhook-setup-whatsapp.ts",
    "webhook:setup:instagram": "tsx scripts/webhook-setup-instagram.ts",
    "webhook:status": "tsx scripts/webhook-setup-telegram.ts info && tsx scripts/webhook-setup-vk.ts && tsx scripts/webhook-setup-whatsapp.ts && tsx scripts/webhook-setup-instagram.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1000.0",
    "@aws-sdk/lib-storage": "^3.1009.0",
    "@aws-sdk/s3-request-presigner": "^3.1009.0",
    "@bull-board/api": "^6.20.3",
    "@bull-board/express": "^6.20.3",
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/qrcode": "^1.5.6",
    "@types/socket.io": "^3.0.2",
    "@voximplant/apiclient-nodejs": "^4.8.0",
    "altcha-lib": "^2.0.3",
    "archiver": "^7.0.1",
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.70.1",
    "cheerio": "^1.2.0",
    "clamscan": "^2.4.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "express-rate-limit": "^7.4.1",
    "firebase-admin": "^13.0.1",
    "heic-convert": "^2.1.0",
    "helmet": "^8.0.0",
    "iconv-lite": "^0.6.3",
    "imapflow": "^1.2.10",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "mailparser": "^3.9.4",
    "multer": "^1.4.5-lts.1",
    "net-snmp": "^3.26.3",
    "nodemailer": "^8.0.1",
    "opossum": "^8.5.0",
    "p-queue": "^9.1.0",
    "pg": "^8.13.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "rate-limit-redis": "^4.3.1",
    "sanitize-html": "^2.17.2",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.1",
    "undici": "^8.1.0",
    "uuid": "^11.1.0",
    "web-push": "^3.6.7",
    "ws": "^8.21.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@swc/core": "^1.15.0",
    "@swc/helpers": "^0.5.17",
    "@types/archiver": "^7.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/ioredis": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/mailparser": "^3.4.6",
    "@types/multer": "^1.4.13",
    "@types/node": "^24.3.1",
    "@types/nodemailer": "^7.0.9",
    "@types/pg": "^8.11.10",
    "@types/pino-http": "^5.8.4",
    "@types/sanitize-html": "^2.16.1",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.34.1",
    "@typescript-eslint/parser": "^8.34.1",
    "eslint": "^9.29.0",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3",
    "vitest": "^4.0.18"
  }
}
